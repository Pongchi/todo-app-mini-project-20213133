{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/index.js" }
  ],
  "functions": {
    "backend/index.js": {
      "memory": 512,
      "maxDuration": 10
    }
  }
}
